# ── DB (change the real value when you copy) ──────────────────
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/fiveweathersDB

# random string (예: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_TO_STRONG_RANDOM_SECRET

# ── Admin first ID/PWD ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ─────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend
BACKEND_CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# data file root
ASSET_BASE_PATH=./data
