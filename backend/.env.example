# ── 필수 항목 (복사 후 실제 값으로 교체) ──────────────────
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@localhost:5432/fiveweathersDB

# 충분히 긴 랜덤 문자열로 반드시 교체 (예: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_TO_STRONG_RANDOM_SECRET

# ── Admin 초기 계정 ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── 선택 항목 ─────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# 허용할 프론트엔드 출처 (쉼표 구분)
BACKEND_CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# 데이터 파일 경로
ASSET_BASE_PATH=./data
